<Page
    x:Class="AmbientSounds.Views.CataloguePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ani="using:Microsoft.Toolkit.Uwp.UI.Animations"
    xmlns:controls="using:AmbientSounds.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ex="using:JeniusApps.Common.UI.Uwp"
    xmlns:labs="using:CommunityToolkit.Labs.WinUI"
    xmlns:local="using:AmbientSounds.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:strings="using:AmbientSounds.Strings"
    xmlns:vm="using:AmbientSounds.ViewModels"
    xmlns:winui="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

    <Grid Margin="{StaticResource MainFramePageMargin}">
        <ScrollViewer CanContentRenderOutsideBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,16,0" Visibility="{x:Bind ViewModel.FiltersEnabled}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <ani:Implicit.ShowAnimations>
                        <ani:OpacityAnimation
                            From="0"
                            To="1"
                            Duration="0:0:0.3" />
                        <ani:TranslationAnimation
                            From="0,12,0"
                            To="0"
                            Duration="0:0:0.3" />
                    </ani:Implicit.ShowAnimations>

                    <labs:TokenView
                        Margin="-4,0,0,0"
                        ItemsSource="{x:Bind ViewModel.CategoryFilters}"
                        ScrollViewer.VerticalScrollMode="Disabled"
                        SelectedItem="{x:Bind ViewModel.SelectedFilter, Mode=TwoWay}">
                        <labs:TokenView.ItemTemplate>
                            <DataTemplate x:DataType="vm:CategoryViewModel">
                                <TextBlock VerticalAlignment="Center" Text="{x:Bind Name}" />
                            </DataTemplate>
                        </labs:TokenView.ItemTemplate>
                    </labs:TokenView>

                    <HyperlinkButton
                        Grid.Column="1"
                        Margin="4,0,0,0"
                        Command="{x:Bind ViewModel.ClearFilterSelectionCommand}"
                        Content="{x:Bind strings:Resources.ClearText}"
                        Visibility="{x:Bind ViewModel.FilteredListVisible, Mode=OneWay}">
                        <ani:Implicit.ShowAnimations>
                            <ani:OpacityAnimation
                                From="0"
                                To="1"
                                Duration="0:0:0.3" />
                            <ani:TranslationAnimation
                                From="12,0,0"
                                To="0"
                                Duration="0:0:0.3" />
                        </ani:Implicit.ShowAnimations>
                    </HyperlinkButton>
                </Grid>

                <ItemsControl
                    Grid.Row="1"
                    Margin="0,12,0,0"
                    ItemsSource="{x:Bind ViewModel.Rows}"
                    Visibility="{x:Bind ex:UIExtensions.InvertBoolToVis(ViewModel.FilteredListVisible), Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CatalogueRowViewModel">
                            <controls:CatalogueRowControl
                                Margin="0,0,0,24"
                                ItemsSource="{x:Bind Sounds, Mode=OneWay}"
                                SoundsVisible="{x:Bind RowVisible, Mode=OneWay}"
                                SparkleIconVisible="{x:Bind NewAnimationVisible, Mode=OneWay}"
                                TitleText="{x:Bind Title, Mode=OneWay}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <controls:CatalogueRowControl
                    Grid.Row="1"
                    Margin="0,12,0,0"
                    ItemsSource="{x:Bind ViewModel.FilteredSounds}"
                    SoundsVisible="True"
                    TitleText="{x:Bind ViewModel.SelectedFilter.Name, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.FilteredListVisible, Mode=OneWay}" />
            </Grid>
        </ScrollViewer>

        <winui:ProgressRing
            Width="40"
            Height="40"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Foreground="{ThemeResource DefaultTextForegroundThemeBrush}"
            IsActive="{x:Bind ViewModel.Loading, Mode=OneWay}"
            Visibility="{x:Bind ViewModel.Loading, Mode=OneWay}" />
    </Grid>
</Page>
